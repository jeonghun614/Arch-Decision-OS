{
  "schema": {
    "name": "void_effect_rules",
    "version": "1.0.0",
    "module": "VERTICAL_VISIBILITY",
    "purpose": "Add vertical visibility score between spaces that share the same void across span floors."
  },

  "global_policy": {
    "apply_only_if_share_same_void": true,
    "pairing_strategy": "WITHIN_ANCHOR_SCOPE_OR_ALL_SPAN",
    "default_vertical_weight": 1.0,
    "max_pairs_per_void": 200,
    "skip_same_space_pair": true,
    "allow_cross_category": true,

    "rounding": {
      "score_precision": 0.01
    }
  },

  "void_type_visibility_defaults": {
    "COURTYARD_VOID": { "base": 0.6, "multiplier": 1.0, "cap": 1.5 },
    "ATRIUM": { "base": 1.0, "multiplier": 1.3, "cap": 4.0 },
    "DOUBLE_HEIGHT": { "base": 0.9, "multiplier": 1.1, "cap": 2.0 },
    "INDUSTRIAL_HIGH_BAY": { "base": 0.8, "multiplier": 1.2, "cap": 3.0 },
    "RAMP_CONTINUUM": { "base": 0.7, "multiplier": 1.15, "cap": 2.5 },
    "LIGHT_WELL": { "base": 0.4, "multiplier": 0.9, "cap": 1.5 },
    "MEZZANINE_OVERLAP": { "base": 0.5, "multiplier": 1.0, "cap": 2.0 }
  },

  "distance_by_floor_gap": [
    { "floor_gap": 0, "factor": 0.0, "note": "same floor - no vertical effect" },
    { "floor_gap": 1, "factor": 1.0 },
    { "floor_gap": 2, "factor": 0.85 },
    { "floor_gap": 3, "factor": 0.7 },
    { "floor_gap": 4, "factor": 0.6 },
    { "floor_gap": 5, "factor": 0.5 }
  ],

  "scope_rules": {
    "mode": "ANCHOR_AND_NEIGHBORS",
    "radius_hops_default": 1,
    "category_allowlist_default": ["SHARED", "CIRCULATION", "BUFFER", "PRIVATE", "SERVICE"]
  },

  "pattern_visibility_adjustments": [
    {
      "if_any_patterns": ["PROTECTION_FIRST", "PRIVACY", "RESTRICTED_ACCESS"],
      "apply": { "multiplier": 0.75 },
      "reason": "privacy-driven projects reduce openness effect"
    },
    {
      "if_any_patterns": ["PUBLIC_HALL", "EXHIBITION_LOOP", "CORE_PERIMETER"],
      "apply": { "multiplier": 1.10 },
      "reason": "public / legible core benefits from vertical openness"
    }
  ],

  "algorithm": {
    "steps": [
      "1) For each void: decide candidate space set S to pair (scope).",
      "2) For each unordered pair (i,j) in S: if they are on different floors, compute V_vertical.",
      "3) floor_gap = abs(floor_i - floor_j). Get factor from distance_by_floor_gap (use last factor if larger).",
      "4) base = void_type_visibility_defaults[void_type].base",
      "5) multiplier = defaults.multiplier * (pattern adjustments) * (voidNode.effects.vertical_visibility.multiplier if present)",
      "6) weight = voidNode.effects.vertical_visibility.weight or global default_vertical_weight",
      "7) V_vertical = base * multiplier * factor * weight",
      "8) Clamp by cap (min(V_vertical, cap)).",
      "9) Emit relation_modifiers log entries (type='VERTICAL_VISIBILITY')."
    ]
  },

  "outputs": {
    "relation_modifiers": {
      "item_shape": {
        "type": "VERTICAL_VISIBILITY",
        "void_id": "string",
        "from_space_id": "string",
        "to_space_id": "string",
        "delta_V_vertical": "number",
        "delta_R": "optional number",
        "meta": {
          "floor_from": "int",
          "floor_to": "int",
          "floor_gap": "int",
          "factor": "number",
          "base": "number",
          "multiplier": "number",
          "weight": "number",
          "cap": "number"
        }
      }
    }
  }
}