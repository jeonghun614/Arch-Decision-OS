    "DC7": {
      "prompt": "설명 없이 이 논리가 읽히는가?",
      "options": {
        "Opaque / Silent Expression (불투명/침묵)": {
          "apply": {
            "grammar.expression_logic.language": "SILENT",
            "grammar.expression_logic.opacity_range": [
              0.8,
              1.0
            ]
          }
        },
        "Transparent / Expressive (투명/표현)": {
          "apply": {
            "grammar.expression_logic.language": "TRANSPARENT",
            "grammar.expression_logic.opacity_range": [
