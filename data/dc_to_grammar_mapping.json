{
  "schema": {
    "name": "dc_to_grammar_mapping",
    "version": "1.0.0"
  },
  "generated_at": "2026-02-21T07:36:38Z",
  "notes": [
    "Purpose: compile DC selections (DC1~DC7) + normalized Axis profile into a single SpatialGrammarSpec.",
    "Merge precedence: defaults < DC mappings < axis adjustments < logic-rule overrides.",
    "Tool-agnostic. Revit MCP tool name mapping should be handled by an adapter."
  ],
  "axis": {
    "enums": {
      "Exposure": [
        "LOW",
        "MID",
        "HIGH"
      ],
      "VisibilityIntent": [
        "BLOCKED",
        "SILHOUETTE",
        "PARTIAL",
        "FRAMED",
        "DIRECT"
      ],
      "AccessControl": [
        "OPEN",
        "CONTROLLED",
        "GATED"
      ],
      "EncounterMode": [
        "AVOID",
        "OPTIONAL",
        "ENCOURAGED",
        "MANDATORY"
      ],
      "SharingMode": [
        "NONE",
        "OPTIONAL",
        "SHARED_CORE",
        "EVERYWHERE"
      ],
      "SeparationMode": [
        "MERGED",
        "BUFFERED",
        "SEPARATED"
      ],
      "Centrality": [
        "CENTRALIZED",
        "DISTRIBUTED",
        "PERIPHERAL"
      ],
      "MassTopology": [
        "MONOLITH",
        "CLUSTER",
        "COURTYARD",
        "LINEAR",
        "STACKED",
        "HYBRID",
        "RING",
        "MODULAR"
      ],
      "Expression": [
        "SILENT",
        "CONTRAST",
        "TRANSPARENT",
        "FILTERED",
        "CODED",
        "HEAVY",
        "LIGHT",
        "RHYTHMIC",
        "MINIMAL"
      ]
    },
    "normalize_hints": {
      "keyword_rules": [
        {
          "if_contains_any": [
            "보호",
            "프라이버시",
            "차단",
            "폐쇄",
            "숨김"
          ],
          "set": {
            "Exposure": "LOW",
            "VisibilityIntent": "BLOCKED",
            "AccessControl": "CONTROLLED"
          }
        },
        {
          "if_contains_any": [
            "노출",
            "공개",
            "투명",
            "개방",
            "표현"
          ],
          "set": {
            "Exposure": "HIGH",
            "VisibilityIntent": "DIRECT",
            "AccessControl": "OPEN"
          }
        },
        {
          "if_contains_any": [
            "완충",
            "버퍼",
            "전이",
            "회색지대",
            "그레이"
          ],
          "set": {
            "SeparationMode": "BUFFERED"
          }
        },
        {
          "if_contains_any": [
            "분리",
            "격리",
            "비공유",
            "단절"
          ],
          "set": {
            "SeparationMode": "SEPARATED",
            "SharingMode": "NONE"
          }
        },
        {
          "if_contains_any": [
            "공유",
            "커뮤니티",
            "만남",
            "연결"
          ],
          "set": {
            "SharingMode": "SHARED_CORE",
            "EncounterMode": "ENCOURAGED"
          }
        }
      ]
    },
    "adjustments": [
      {
        "when": {
          "Exposure": "LOW"
        },
        "apply": {
          "grammar.visibility_control.target_range": [
            0,
            2
          ],
          "grammar.buffer.require_buffer_between_private_shared": true
        }
      },
      {
        "when": {
          "Exposure": "HIGH"
        },
        "apply": {
          "grammar.visibility_control.target_range": [
            3,
            4
          ]
        }
      },
      {
        "when": {
          "Centrality": "DISTRIBUTED"
        },
        "apply": {
          "grammar.topology.cluster_count_range": [
            3,
            6
          ],
          "grammar.topology.centrality": "DISTRIBUTED"
        }
      },
      {
        "when": {
          "Centrality": "CENTRALIZED"
        },
        "apply": {
          "grammar.topology.cluster_count_range": [
            1,
            2
          ],
          "grammar.topology.centrality": "CENTRALIZED"
        }
      },
      {
        "when": {
          "SeparationMode": "BUFFERED"
        },
        "apply": {
          "grammar.buffer.strategy": "BUFFER_FIELDS",
          "grammar.buffer.forbid_direct_private_shared": true
        }
      },
      {
        "when": {
          "SharingMode": "EVERYWHERE"
        },
        "apply": {
          "grammar.program.area_bias.SHARED": 0.1,
          "grammar.program.area_bias.PRIVATE": -0.1,
          "grammar.relations.shared_min_adjacency": 3
        }
      }
    ]
  },
  "merge_strategy": {
    "precedence": [
      "defaults",
      "dc",
      "axis",
      "logic_rules"
    ],
    "array_merge": "replace",
    "object_merge": "deep_merge",
    "numeric_merge": "overwrite_unless_additive",
    "additive_fields_prefix": [
      "grammar.program.area_bias"
    ]
  },
