  },
  "dc": {
    "DC1": {
      "prompt": "이 프로젝트가 끝까지 지켜야 할 핵심 문제는 무엇인가?",
      "options": {
        "관계 피로 / 접속의 통제 불가": {
          "apply": {
            "grammar.buffer.strategy": "STAGED_TRANSITION",
            "grammar.buffer.require_buffer_between_private_shared": true,
            "grammar.circulation.shared_not_gate": true
          }
        },
        "고립 / 사회적 접점 부족": {
          "apply": {
            "grammar.visibility_control.target_range": [
              2,
              4
            ],
            "grammar.circulation.optional_detour": true
          }
        },
        "우연의 과잉 / 마주침 과부하": {
          "apply": {
            "grammar.circulation.time_layered": true
          }
        },
        "사생활 침해 / 시선 노출": {
          "apply": {
            "grammar.buffer.strategy": "SCREEN_FILTER",
            "grammar.visibility_control.target_range": [
              1,
              3
            ]
          }
        },
        "공유의 강요 / 선택권 결여": {
          "apply": {
            "grammar.topology.type": "LINEAR",
            "grammar.topology.centrality": "PERIPHERAL"
          }
        },
        "경제성 / 면적 효율": {
          "apply": {
            "grammar.topology.type": "MONOLITH",
            "grammar.topology.cluster_count_range": [
              1,
              1
            ]
          }
        },
        "운영 지속 가능성 / 관리 부담": {
          "apply": {
            "grammar.structural_logic.grid_based": true,
            "grammar.structural_logic.expandable": true
          }
        },
        "메시지/상징성 / 사회적 발언": {
          "apply": {
            "grammar.expression_logic.language": "CONTRAST",
            "grammar.expression_logic.rhythm": "STRONG"
          }
        }
      }
    },
    "DC2": {
      "prompt": "이 문제를 공간적으로 어떤 태도로 다룰 것인가?",
      "options": {
        "ON/OFF 이분 구조 (Binary Control)": {
          "apply": {
            "grammar.buffer.strategy": "BINARY_ONOFF",
            "grammar.buffer.require_buffer_between_private_shared": true
          }
        },
        "연속적 스펙트럼 (Gradient Control)": {
          "apply": {
            "grammar.buffer.strategy": "GRADIENT",
            "grammar.circulation.staged_entry": true
          }
        },
        "완충 중심 구조 (Buffer-mediated)": {
          "apply": {
            "grammar.buffer.strategy": "BUFFER_FIELDS",
            "grammar.buffer.require_buffer_between_private_shared": true,
            "grammar.buffer.forbid_direct_private_shared": true
          }
        },
        "보호 우선 구조 (Protection-first)": {
          "apply": {
            "grammar.visibility_control.target_range": [
              0,
              2
            ],
            "grammar.buffer.strategy": "SCREEN_FILTER"
          }
        },
        "노출 우선 구조 (Exposure-first)": {
          "apply": {
            "grammar.visibility_control.target_range": [
              3,
              4
            ],
            "grammar.buffer.strategy": "NONE"
          }
        }
      }
    },
    "DC3": {
      "prompt": "프로그램은 어떻게 작동해야 하는가?",
      "options": {
        "Terminal Program (목적지형 공유)": {
          "apply": {
            "grammar.circulation.type": "DEAD_END_ALLOWED"
          }
        },
        "Mandatory Passage Program (필수 경유 공유)": {
          "apply": {
            "grammar.circulation.shared_not_gate": false
          }
        },
        "Parallel Programs (병렬 프로그램)": {
          "apply": {
            "grammar.circulation.type": "PARALLEL"
          }
        },
        "Buffer Programs (완충 프로그램)": {
          "apply": {
            "grammar.buffer.strategy": "BUFFER_FIELDS",
            "grammar.buffer.require_buffer_between_private_shared": true
          }
        },
        "Time-Separated Program (시간 분리 운영)": {
          "apply": {
            "grammar.circulation.time_layered": true
          }
        },
        "User-Initiated Program (사용자 호출형)": {
          "apply": {
            "grammar.circulation.optional_detour": true
          }
        },
        "Always-On Program (상시 작동 공유)": {
          "apply": {
            "grammar.topology.centrality": "CENTRALIZED"
          }
        },
        "Non-shared (비공유)": {
          "apply": {
            "grammar.program.area_bias.SHARED": -0.1,
            "grammar.program.area_bias.PRIVATE": 0.1,
            "grammar.buffer.forbid_direct_private_shared": true
          }
        }
      }
    },
    "DC4": {
      "prompt": "지금까지의 논리가 요구하는 덩어리 관계는?",
      "options": {
        "Clustered Mass (군집 분절)": {
          "apply": {
            "grammar.topology.type": "CLUSTER",
            "grammar.topology.cluster_count_range": [
              3,
              6
            ]
          }
        },
        "Monolithic Mass (단일체)": {
          "apply": {
            "grammar.topology.type": "MONOLITH",
            "grammar.topology.cluster_count_range": [
              1,
              1
            ]
          }
        },
        "Linear Bar (선형 바)": {
          "apply": {
            "grammar.topology.type": "LINEAR",
            "grammar.topology.cluster_count_range": [
              2,
              4
            ]
          }
        },
        "Courtyard-Based (중정 기반)": {
          "apply": {
            "grammar.topology.type": "COURTYARD",
            "grammar.buffer.strategy": "COURTYARD_VOID"
          }
        },
        "Central Placement (중앙 배치)": {
          "apply": {
            "grammar.topology.centrality": "CENTRALIZED",
