        "비마주침/직통 (Skip-access / Non-encounter)": {
          "apply": {
            "grammar.circulation.type": "SKIP_ACCESS",
            "grammar.circulation.skip_access": true
          }
        }
      }
    },
    "DC6": {
      "prompt": "이 논리를 구조적으로 어떻게 증명하는가?",
      "options": {
        "Structure-Independent Space (구조-공간 독립)": {
          "apply": {
            "grammar.structural_logic.independent_modules": true,
            "grammar.structural_logic.system": "INDEPENDENT"
          }
        },
        "Integrated Structural System (일체형 구조)": {
          "apply": {
            "grammar.structural_logic.system": "INTEGRATED"
          }
        },
        "Service-Core Dominant (서비스 코어 지배)": {
          "apply": {
            "grammar.structural_logic.core_dominant": true,
            "grammar.structural_logic.system": "CORE_DOMINANT"
          }
        },
        "Distributed Structural Supports (분산 지지)": {
          "apply": {
            "grammar.structural_logic.wall_dominant": true,
            "grammar.structural_logic.system": "WALL_BEARING"
          }
        }
      }
