          "apply": {
            "grammar.expression_logic.language": "MINIMAL",
            "grammar.expression_logic.rhythm": "UNIFIED"
          }
        },
        "Semi-Transparent Filtering (반투명 필터)": {
          "apply": {
            "grammar.expression_logic.language": "LIGHT",
            "grammar.expression_logic.opacity_range": [
              0.2,
              0.6
            ]
          }
        }
      }
    }
  },
  "logic_rules_overrides": {
    "concept": "Optional: convert your Logic Rule hits into grammar patches.",
    "rules": [
      {
        "when_rule_type_in": [
          "exclude"
        ],
        "apply": {
          "grammar.validation.hard_constraints_enforced": true
        }
      }
    ]
  }
