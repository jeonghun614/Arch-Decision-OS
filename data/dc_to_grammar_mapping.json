    "DC5": {
      "prompt": "사용자는 어떤 ‘선택의 순서’를 경험하는가?",
      "options": {
        "이중 동선 (Dual-layer Circulation)": {
          "apply": {
            "grammar.circulation.type": "DUAL_LAYER",
            "grammar.circulation.min_routes": 2
          }
