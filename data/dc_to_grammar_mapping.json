        "단일 경로 (Single-path Circulation)": {
          "apply": {
            "grammar.circulation.type": "SINGLE",
            "grammar.circulation.min_routes": 1
          }
        },
        "선택적 우회 (Optional Detour)": {
          "apply": {
            "grammar.circulation.type": "OPTIONAL_DETOUR",
            "grammar.circulation.min_routes": 2,
            "grammar.circulation.optional_detour": true
