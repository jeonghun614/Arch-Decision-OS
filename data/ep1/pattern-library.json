{
  "schema": {
    "name": "universal_pattern_library",
    "version": "1.0.0",
    "description": "Pattern blocks for generating Program Tree (Category→Cluster→Space) and Relations Graph. Typology is not fixed; patterns are composed."
  },

  "enums": {
    "category_labels": ["PRIMARY", "PRIVATE", "SHARED", "BUFFER", "SERVICE", "CIRCULATION", "VOID"],
    "access_levels": ["OPEN", "CONTROLLED", "RESTRICTED"],
    "visibility_levels": [0, 1, 2, 3, 4],
    "operating_hours": ["STATIC", "SCHEDULED", "EVENT", "CONTINUOUS_24H"],
    "span_types": ["SINGLE_FLOOR", "MULTI_LEVEL"]
  },

  "rules": {
    "composition": {
      "max_patterns": 6,
      "min_patterns": 2,
      "conflict_handling": "SOFT_WARN",
      "priority_order": [
        "SEPARATION",
        "ORGANIZATION",
        "CIRCULATION",
        "PUBLICNESS",
        "SPACE_KITS",
        "VOID"
      ]
    },
    "area_distribution": {
      "category_total_source": "grammar.program.base_ratios",
      "space_min_area_enforcement": true,
      "rounding_m2": 1,
      "max_total_error_percent": 2.0
    },
    "relations": {
      "relation_formula": "R = A + V",
      "relation_formula_note": "A_target (0–5): adjacency/access desire. V_target (0–4): visibility desire. 이 파일의 relation_actions는 클러스터 레벨 의미 표현이며, 실제 엔진 score(-5..+5) 및 relation_type으로의 변환은 relation_auto_generation_rules § cluster_relation_seeds.conversion 에서 정의됨.",
      "vertical_visibility_enabled": true,
      "default_vertical_weight": 0.6
    }
  },

  "pattern_blocks": [
    {
      "id": "ORG_CORE_PERIMETER",
      "family": "ORGANIZATION",
      "label": "Core + Perimeter",
      "intent": "Stabilize services/vertical circulation in a core; allocate program around perimeter for daylight & legibility.",
      "triggers": {
        "domain_bias": ["OFFICE", "EDUCATION", "HEALTHCARE", "RETAIL", "MIXED"],
        "spatial_intensity": ["CELLULAR", "HYBRID"],
        "vertical_intensity": ["MODERATE", "HIGH"]
      },
      "program_actions": {
        "cluster_templates": [
          {
            "cluster_name": "Vertical & Service Core",
            "category_label": "SERVICE",
            "weight": 0.18,
            "space_kits": ["KIT_VERTICAL_CORE", "KIT_MEP_SHAFTS"]
          },
          {
            "cluster_name": "Perimeter Program Band",
            "category_label": "PRIMARY",
            "weight": 0.55,
            "space_kits": ["KIT_GENERIC_PRIMARY_CELLULAR"]
          },
          {
            "cluster_name": "Public Interface Strip",
            "category_label": "SHARED",
            "weight": 0.12,
            "space_kits": ["KIT_ENTRY_LOBBY_RECEPTION"]
          },
          {
            "cluster_name": "Circulation Network",
            "category_label": "CIRCULATION",
            "weight": 0.15,
            "space_kits": ["KIT_CORRIDORS_STAIRS"]
          }
        ],
        "placement_bias": {
          "SERVICE": { "floor_preference": { "preferred": [], "avoid": [], "min_floor": 1, "max_floor": 999 } },
          "SHARED": { "floor_preference": { "preferred": [1], "avoid": [], "min_floor": 1, "max_floor": 2 } }
        }
      },
      "relation_actions": {
        "default_relations": [
          { "from_cluster": "Vertical & Service Core", "to_cluster": "Perimeter Program Band", "A_target": 4, "V_target": 1, "weight": 1.0, "reason": "Core supports perimeter program." },
          { "from_cluster": "Public Interface Strip", "to_cluster": "Perimeter Program Band", "A_target": 3, "V_target": 2, "weight": 0.8, "reason": "Public interface connects to primary." }
        ],
        "avoid_relations": [
          { "from_cluster": "Public Interface Strip", "to_cluster": "Vertical & Service Core", "A_target": 1, "V_target": 0, "weight": 0.6, "reason": "Avoid exposing core/BOH." }
        ]
      }
    },

    {
      "id": "ORG_DISTRIBUTED_CLUSTERS",
      "family": "ORGANIZATION",
      "label": "Distributed Clusters",
      "intent": "Split program into multiple clusters to reduce forced encounter and increase parallel use.",
      "triggers": {
        "domain_bias": ["CAMPUS", "RESIDENTIAL", "CULTURAL", "RESEARCH", "MIXED"],
        "spatial_intensity": ["CELLULAR", "HYBRID"],
        "vertical_intensity": ["LOW", "MODERATE"]
      },
      "program_actions": {
        "global_overrides": {
          "centrality_hint": "DISTRIBUTED"
        },
        "cluster_templates": [
          { "cluster_name": "Primary Cluster A", "category_label": "PRIMARY", "weight": 0.32, "space_kits": ["KIT_GENERIC_PRIMARY_CELLULAR"] },
          { "cluster_name": "Primary Cluster B", "category_label": "PRIMARY", "weight": 0.23, "space_kits": ["KIT_GENERIC_PRIMARY_CELLULAR"] },
          { "cluster_name": "Shared Commons", "category_label": "SHARED", "weight": 0.15, "space_kits": ["KIT_COMMONS"] },
          { "cluster_name": "Buffers & Thresholds", "category_label": "BUFFER", "weight": 0.10, "space_kits": ["KIT_BUFFERS_THRESHOLDS"] },
          { "cluster_name": "Service Support", "category_label": "SERVICE", "weight": 0.10, "space_kits": ["KIT_MEP_GENERAL", "KIT_STORAGE_GENERAL"] },
          { "cluster_name": "Circulation Links", "category_label": "CIRCULATION", "weight": 0.10, "space_kits": ["KIT_LINKS_PATHS"] }
        ],
        "placement_bias": {
          "BUFFER": { "floor_preference": { "preferred": [1], "avoid": [], "min_floor": 1, "max_floor": 999 } }
        }
      },
      "relation_actions": {
        "default_relations": [
          { "from_cluster": "Shared Commons", "to_cluster": "Primary Cluster A", "A_target": 3, "V_target": 2, "weight": 1.0, "reason": "Commons supports primary." },
          { "from_cluster": "Shared Commons", "to_cluster": "Primary Cluster B", "A_target": 3, "V_target": 2, "weight": 1.0, "reason": "Commons supports primary." },
          { "from_cluster": "Buffers & Thresholds", "to_cluster": "Shared Commons", "A_target": 4, "V_target": 1, "weight": 0.8, "reason": "Buffer mediates shared space." }
        ],
        "avoid_relations": []
      }
    },

    {
      "id": "SEP_PUBLIC_CONTROLLED_RESTRICTED",
      "family": "SEPARATION",
      "label": "Public / Controlled / Restricted Hierarchy",
      "intent": "Layer access to prevent unwanted exposure and enforce security gradient.",
      "triggers": {
        "security_level": ["CONTROLLED", "RESTRICTED"],
        "publicness_level": ["SEMI_PUBLIC", "PUBLIC"]
      },
      "program_actions": {
        "space_overrides": [
          {
            "match": { "category_label": "SHARED" },
            "set": { "access_visibility": { "access_level": "OPEN", "visibility_level": 3 } }
          },
          {
            "match": { "category_label": "PRIMARY" },
            "set": { "access_visibility": { "access_level": "CONTROLLED", "visibility_level": 2 } }
          },
          {
            "match": { "category_label": "PRIVATE" },
            "set": { "access_visibility": { "access_level": "RESTRICTED", "visibility_level": 1 } }
          }
        ],
        "placement_bias": {
          "SHARED": { "floor_preference": { "preferred": [1], "avoid": [], "min_floor": 1, "max_floor": 2 } },
          "PRIVATE": { "floor_preference": { "preferred": [], "avoid": [1], "min_floor": 2, "max_floor": 999 } }
        }
      },
      "relation_actions": {
        "default_relations": [],
        "avoid_relations": [
          { "from_category": "SHARED", "to_category": "PRIVATE", "A_target": 1, "V_target": 0, "weight": 1.0, "reason": "Avoid direct adjacency between public and private." }
        ]
      }
    },

    {
      "id": "CIRC_LOOP",
      "family": "CIRCULATION",
      "label": "Loop Circulation",
      "intent": "Enable continuous movement and distribute encounters; good for galleries, campuses, commons, courtyards.",
      "triggers": {
        "circulation_hint": ["LOOP"],
        "spatial_intensity": ["HYBRID", "LARGE_SPAN"]
      },
      "program_actions": {
        "cluster_templates_append": [
          { "cluster_name": "Loop Spine", "category_label": "CIRCULATION", "weight": 0.08, "space_kits": ["KIT_LOOP_SPINE"] }
        ]
      },
      "relation_actions": {
        "default_relations": [
          { "from_cluster": "Loop Spine", "to_category": "PRIMARY", "A_target": 4, "V_target": 1, "weight": 0.8, "reason": "Loop supports primary navigation." },
          { "from_cluster": "Loop Spine", "to_category": "SHARED", "A_target": 3, "V_target": 2, "weight": 0.8, "reason": "Loop connects shared nodes." }
        ],
        "avoid_relations": []
      }
    },

    {
      "id": "CIRC_DUAL_LAYER",
      "family": "CIRCULATION",
      "label": "Dual-layer Circulation",
      "intent": "Separate resident/staff/back-of-house circulation from public circulation to reduce interference.",
      "triggers": {
        "operational_complexity": ["SCHEDULED", "CONTINUOUS_24H"],
        "security_level": ["CONTROLLED", "RESTRICTED"]
      },
      "program_actions": {
        "cluster_templates_append": [
          { "cluster_name": "Back-of-House Circulation", "category_label": "CIRCULATION", "weight": 0.07, "space_kits": ["KIT_BACK_OF_HOUSE_PATHS"] }
        ],
        "space_overrides": [
          {
            "match": { "cluster_name": "Back-of-House Circulation" },
            "set": { "access_visibility": { "access_level": "RESTRICTED", "visibility_level": 0 } }
          }
        ]
      },
      "relation_actions": {
        "default_relations": [
          { "from_cluster": "Back-of-House Circulation", "to_category": "SERVICE", "A_target": 5, "V_target": 0, "weight": 1.0, "reason": "BOH must strongly connect to service." }
        ],
        "avoid_relations": []
      }
    },

    {
      "id": "VOID_ATRIUM_CANDIDATE",
      "family": "VOID",
      "label": "Atrium Candidate",
      "intent": "Introduce multi-level void to enhance orientation, daylight, and vertical visibility connections.",
      "triggers": {
        "vertical_intensity": ["MODERATE", "HIGH"],
        "publicness_level": ["SEMI_PUBLIC", "PUBLIC"]
      },
      "program_actions": {
        "void_suggestions": [
          {
            "name": "Atrium",
            "void_type": "ATRIUM",
            "default_span": { "from_floor": 1, "to_floor": 2 },
            "area_effect": { "subtract_footprint_ratio_per_floor": 1.0 },
            "relation_effect": { "visibility_multiplier": 1.2 }
          }
        ]
      },
      "relation_actions": {
        "default_relations": [],
        "avoid_relations": []
      }
    },

    {
      "id": "VOID_COURTYARD_CANDIDATE",
      "family": "VOID",
      "label": "Courtyard Void Candidate",
      "intent": "Introduce courtyard void for buffering, daylight, and loop organization; compatible with courtyard topology.",
      "triggers": {
        "topology_hint": ["COURTYARD"],
        "separation_hint": ["BUFFERED"]
      },
      "program_actions": {
        "void_suggestions": [
          {
            "name": "Courtyard Void",
            "void_type": "COURTYARD_VOID",
            "default_span": { "from_floor": 1, "to_floor": 2 },
            "area_effect": { "subtract_footprint_ratio_per_floor": 1.0 },
            "relation_effect": { "visibility_multiplier": 1.15 }
          }
        ],
        "cluster_templates_append": [
          { "cluster_name": "Courtyard Buffer Ring", "category_label": "BUFFER", "weight": 0.06, "space_kits": ["KIT_COURTYARD_RING"] }
        ]
      },
      "relation_actions": {
        "default_relations": [
          { "from_cluster": "Courtyard Buffer Ring", "to_category": "PRIMARY", "A_target": 4, "V_target": 2, "weight": 0.7, "reason": "Buffer ring mediates courtyard to primary." }
        ],
        "avoid_relations": []
      }
    }
  ],

